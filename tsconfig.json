{
    "compilerOptions": {
        "target": "ES2021",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "lib": ["ES2021", "DOM"],
        "types": ["vitest/globals"]
    },
    "include": ["src"]
}
